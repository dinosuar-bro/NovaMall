# MySQL 应用连接
DATABASE_URL=mysql://novamall:请替换为强密码@mysql:3306/novamall
TEST_DATABASE_URL=mysql://novamall:请替换为强密码@127.0.0.1:3308/novamall_test

# 服务端安全配置：请分别生成至少 32 字节随机值，不要复用
SESSION_SECRET=请替换为至少32字符随机值
PHONE_AES_KEY=请替换为32字节随机值

# 运行环境
NODE_ENV=development
API_PORT=3000
WEB_ORIGIN=http://localhost:8080
